datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String
  password  String
  role      String   @default("customer") // 'customer' | 'admin' | 'delivery'
  address   String?
  city      String?
  zipCode   String?
  latitude  Float?
  longitude Float?
  profileImage String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders           Order[]
  payments         Payment[]
  deliveryTransfers DeliveryTracking[] @relation("DeliveryPerson")
  assignedOrders   Order[] @relation("DeliveryPerson")
  notifications    Notification[]
  addresses        Address[]
  conversations    ChatConversation[]
}

model MenuItem {
  id            String   @id @default(uuid())
  name          String
  category      String // 'snacks' | 'curries' | 'desserts' | 'breads'
  description   String?
  price         Float
  image         String // Cloudinary URL
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  isVegetarian  Boolean  @default(true)
  spiceLevel    String? // 'mild' | 'medium' | 'hot'
  preparationTime Int? // minutes
  availability  Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderItems OrderItem[]
}

model Order {
  id               String   @id @default(uuid())
  customerId       String
  customer         User     @relation(fields: [customerId], references: [id])
  items            OrderItem[]
  subtotal         Float
  tax              Float
  deliveryFee      Float
  totalAmount      Float
  status           String   @default("pending") // 'pending' | 'confirmed' | 'preparing' | 'ready' | 'out_for_delivery' | 'delivered' | 'cancelled'
  paymentMethod    String // 'stripe' | 'momo' | 'cash'
  paymentStatus    String   @default("pending") // 'pending' | 'completed' | 'failed'
  deliveryAddress  String
  deliveryPersonId String?
  deliveryPerson   User?    @relation(name: "DeliveryPerson", fields: [deliveryPersonId], references: [id])
  specialInstructions String?
  rating           Int?
  review           String?
  estimatedDeliveryTime DateTime?
  actualDeliveryTime DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  payment          Payment?
  tracking         DeliveryTracking?
  notifications     Notification[]
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  price      Float // price at time of order

  @@unique([orderId, menuItemId])
}

model Payment {
  id                      String   @id @default(uuid())
  orderId                 String   @unique
  order                   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId                  String
  user                    User     @relation(fields: [userId], references: [id])
  amount                  Float
  currency                String   @default("USD")
  paymentMethod           String // 'stripe' | 'momo' | 'cash'
  transactionId           String?
  status                  String   @default("pending") // 'pending' | 'completed' | 'failed' | 'refunded'
  paymentGatewayResponse  Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model DeliveryTracking {
  id                String   @id @default(uuid())
  orderId           String   @unique
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deliveryPersonId  String?
  deliveryPerson    User?    @relation(name: "DeliveryPerson", fields: [deliveryPersonId], references: [id])
  currentLat        Float?
  currentLng        Float?
  deliveryRoute     Json? // Array of {lat, lng, timestamp}
  estimatedArrival  DateTime?
  status            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // 'order_placed' | 'order_confirmed' | 'preparing' | 'ready_for_pickup' | 'out_for_delivery' | 'delivered' | 'cancelled' | 'payment_received' | 'payment_failed'
  title     String
  message   String
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id])
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

model Address {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String   // e.g., 'Home', 'Work', 'Other'
  fullAddress String
  city        String?
  zipCode     String?
  latitude    Float?
  longitude   Float?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model ChatConversation {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  adminId     String?
  status      String   @default("active") // 'active' | 'closed'
  lastMessage String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    ChatMessage[]
  @@index([userId])
}

model ChatMessage {
  id             String   @id @default(uuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  senderType     String   // 'user' | 'admin'
  content        String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([conversationId])
}
