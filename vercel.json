{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "output": "frontend"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://dwarkeshfood-production.up.railway.app/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "https://dwarkeshfood-production.up.railway.app/api",
    "VITE_SOCKET_URL": "https://dwarkeshfood-production.up.railway.app"
  }
}